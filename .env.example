# Kopyalayın: copy .env.example .env  (Linux/macOS: cp .env.example .env)
# Bu dosyayı düzenleyip .env olarak kaydedin; .env Git'e eklenmez (.gitignore).

DATABASE_URL=postgresql+asyncpg://admin:secret_password@127.0.0.1:5432/kobi_os
GEMINI_API_KEY=your-google-genai-key
PROJECT_NAME=Syntra
DEBUG=false

# Yerel Streamlit → yerel API (varsayılan kod: http://127.0.0.1:8000)
# SYNTRA_API_BASE_URL=http://127.0.0.1:8000
# Farklı port: SYNTRA_API_BASE_URL=http://127.0.0.1:8080
# Docker Compose UI konteyneri için compose dosyasında http://api:8000 atanır; burada tanımlamanız şart değil.
